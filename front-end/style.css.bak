:root {
  --green-dark: #2d8a4e;
  --green-mid: #4caf50;
  --green-light: #e8f5e9;
  --cream: #fffdf7;
  --white: #ffffff;
  --black: #1a1a1a;
  --text-muted: #666666;
  --shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
  --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

body {
  font-family: 'Inter', sans-serif;
  color: var(--black);
  background-color: var(--white);
  line-height: 1.6;
  overflow-x: hidden;
}

h1,
h2,
h3,
.logo {
  font-family: 'Playfair Display', serif;
}

.container {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 20px;
}

.mt-4 {
  margin-top: 2rem;
}

.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

/* Navigation */
.navbar {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  z-index: 1000;
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(10px);
  border-bottom: 1px solid var(--green-light);
  padding: 15px 0;
}

.nav-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.logo-link {
  display: flex;
  align-items: center;
  gap: 10px;
  text-decoration: none;
}

.logo-icon {
  border-radius: 10px;
  transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  flex-shrink: 0;
}

.logo-link:hover .logo-icon {
  transform: rotate(10deg) scale(1.1);
}

.logo-text {
  font-family: 'Playfair Display', serif;
  font-size: 1.4rem;
  font-weight: 800;
  color: var(--green-dark);
}

.logo span {
  color: var(--black);
}

.nav-links a {
  text-decoration: none;
  color: var(--black);
  margin: 0 15px;
  font-weight: 500;
  font-size: 0.95rem;
  transition: var(--transition);
}

.nav-links a:hover {
  color: var(--green-mid);
}

.nav-search {
  display: flex;
  background: var(--green-light);
  padding: 5px 15px;
  border-radius: 50px;
}

.nav-search input {
  border: none;
  background: transparent;
  outline: none;
  padding: 5px;
  font-size: 0.9rem;
  width: 150px;
}

.nav-search button {
  border: none;
  background: transparent;
  cursor: pointer;
}

/* Hero Section */
.hero {
  position: relative;
  min-height: 90vh;
  /* Increased height for premium feel */
  background: var(--bg-light);
  display: flex;
  align-items: center;
  overflow: hidden;
  padding-top: 80px;
}

.hero-overlay {
  display: none;
}

.hero-container {
  display: grid;
  grid-template-columns: 1.2fr 0.8fr;
  align-items: center;
  gap: 40px;
  position: relative;
  z-index: 2;
  width: 100%;
}

.hero-content {
  max-width: 600px;
  color: var(--black);
  animation: fadeUp 1s ease-out;
}

.hero-content h1 {
  font-family: 'Playfair Display', serif;
  font-size: 4rem;
  line-height: 1.1;
  margin-bottom: 24px;
  font-weight: 800;
}

.hero-content h1 span {
  color: var(--green-dark);
}

.hero-content p {
  font-size: 1.2rem;
  color: #555;
  line-height: 1.6;
  margin-bottom: 32px;
}

.hero-visual {
  position: relative;
  display: flex;
  justify-content: center;
  align-items: center;
}

.hero-food-img {
  width: 130%;
  max-width: 600px;
  height: auto;
  z-index: 2;
  filter: drop-shadow(0 20px 50px rgba(0, 0, 0, 0.1));
  animation: floatBurger 6s ease-in-out infinite, entryBurger 1.5s cubic-bezier(0.2, 0.8, 0.2, 1);
}

.food-shadow {
  position: absolute;
  bottom: -40px;
  width: 60%;
  height: 30px;
  background: radial-gradient(ellipse at center, rgba(0, 0, 0, 0.1) 0%, rgba(0, 0, 0, 0) 70%);
  border-radius: 50%;
  z-index: 1;
  animation: floatShadow 6s ease-in-out infinite;
}

@keyframes floatBurger {

  0%,
  100% {
    transform: translateY(0) rotate(0);
  }

  50% {
    transform: translateY(-30px) rotate(2deg);
  }
}

@keyframes floatShadow {

  0%,
  100% {
    transform: scale(1.1);
    opacity: 0.8;
  }

  50% {
    transform: scale(0.8);
    opacity: 0.4;
  }
}

@keyframes entryBurger {
  0% {
    transform: translateX(100px) scale(0.8);
    opacity: 0;
  }

  100% {
    transform: translateX(0) scale(1);
    opacity: 1;
  }
}

.scroll-indicator {
  position: absolute;
  bottom: 30px;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  flex-direction: column;
  items: center;
  gap: 8px;
  opacity: 0.6;
  text-align: center;
}

.mouse {
  width: 24px;
  height: 36px;
  border: 2px solid var(--black);
  border-radius: 12px;
  margin: 0 auto;
  position: relative;
}

.mouse::before {
  content: '';
  position: absolute;
  top: 6px;
  left: 50%;
  transform: translateX(-50%);
  width: 4px;
  height: 8px;
  background: var(--black);
  border-radius: 2px;
  animation: mouseWheel 2s infinite;
}

@keyframes mouseWheel {
  0% {
    top: 6px;
    opacity: 1;
  }

  100% {
    top: 20px;
    opacity: 0;
  }
}


@keyframes fadeUp {
  from {
    opacity: 0;
    transform: translateY(30px);
  }

  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.hero-badge {
  background: var(--green-mid);
  padding: 5px 15px;
  border-radius: 20px;
  font-size: 0.8rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 1px;
  margin-bottom: 20px;
  display: inline-block;
}

.hero h1 {
  font-size: 3.5rem;
  margin-bottom: 20px;
  line-height: 1.2;
}

.hero p {
  font-size: 1.1rem;
  margin-bottom: 30px;
  opacity: 0.9;
}

.btn {
  padding: 12px 30px;
  border-radius: 50px;
  text-decoration: none;
  font-weight: 600;
  transition: var(--transition);
  display: inline-block;
}

.btn-primary {
  background: var(--green-mid);
  color: var(--white);
  margin-right: 15px;
}

.btn-primary:hover {
  background: var(--green-dark);
  transform: translateY(-3px);
}

.btn-secondary {
  background: rgba(255, 255, 255, 0.2);
  color: var(--white);
  backdrop-filter: blur(5px);
}

.btn-secondary:hover {
  background: rgba(255, 255, 255, 0.3);
}

.btn-outline {
  border: 2px solid var(--green-mid);
  color: var(--green-dark);
}

.btn-outline:hover {
  background: var(--green-mid);
  color: var(--white);
}

/* Stats Bar */
.stats-bar {
  background: var(--cream);
  padding: 40px 0;
  border-bottom: 1px solid #eee;
}

.stats-container {
  display: flex;
  justify-content: space-around;
  flex-wrap: wrap;
}

.stat-item {
  display: flex;
  align-items: center;
  padding: 10px 20px;
}

.stat-icon {
  font-size: 2.5rem;
  margin-right: 15px;
}

.stat-info h3 {
  font-size: 1.8rem;
  color: var(--green-dark);
}

.stat-info p {
  font-size: 0.9rem;
  color: var(--text-muted);
}

/* Sections */
.section {
  padding: 80px 0;
}

.section-alt {
  background: var(--cream);
}

.section-header {
  text-align: center;
  margin-bottom: 50px;
}

.section-header h2 {
  font-size: 2.5rem;
  margin-bottom: 10px;
}

.section-header p {
  color: var(--text-muted);
}

/* Recipe Grid */
.recipe-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 30px;
}

.recipe-card {
  background: var(--white);
  border-radius: 20px;
  overflow: hidden;
  box-shadow: var(--shadow);
  transition: var(--transition);
  cursor: pointer;
  border: 1px solid #f0f0f0;
}

.recipe-card:hover {
  transform: translateY(-10px);
  box-shadow: 0 20px 40px rgba(0, 0, 0, 0.12);
}

/* Real photo header (Pexels) */
.card-img-real {
  height: 200px;
  background-size: cover;
  background-position: center;
  position: relative;
  overflow: hidden;
  transition: transform 0.4s ease;
}

.recipe-card:hover .card-img-real {
  transform: scale(1.05);
}

.card-img-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to bottom, transparent 50%, rgba(0, 0, 0, 0.25) 100%);
}

.card-img-gradient {
  height: 200px;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
}

.card-img-gradient::after {
  content: '';
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.15);
}

.card-emoji {
  font-size: 5rem;
  position: relative;
  z-index: 1;
  filter: drop-shadow(0 4px 12px rgba(0, 0, 0, 0.35));
  transition: transform 0.3s ease;
  line-height: 1;
}

.recipe-card:hover .card-emoji {
  transform: scale(1.15) rotate(-5deg);
}

.card-content {
  padding: 20px;
}

.card-content h3 {
  font-size: 1.2rem;
  margin-bottom: 10px;
  height: 2.8rem;
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  line-clamp: 2;
  -webkit-box-orient: vertical;
}

.card-meta {
  display: flex;
  justify-content: space-between;
  font-size: 0.85rem;
  color: var(--text-muted);
}

/* Category Row */
.category-row {
  display: flex;
  justify-content: center;
  gap: 40px;
  flex-wrap: wrap;
}

.category-card {
  text-align: center;
  cursor: pointer;
  transition: var(--transition);
}

.category-card {
  text-align: center;
  cursor: pointer;
  transition: var(--transition);
}

.category-card:hover {
  transform: translateY(-5px);
}

.cat-image {
  width: 130px;
  height: 130px;
  border-radius: 50%;
  background-size: cover;
  background-position: center;
  margin: 0 auto 15px;
  border: 4px solid var(--white);
  box-shadow: var(--shadow);
  transition: var(--transition);
}

.category-card:hover .cat-image {
  border-color: var(--green-dark);
  box-shadow: 0 15px 30px rgba(0, 0, 0, 0.15);
}


/* Ingredient Search */
.ingredient-search-box {
  max-width: 600px;
  margin: 0 auto;
}

.search-wrapper {
  display: flex;
  gap: 10px;
}

.search-wrapper input {
  flex: 1;
  padding: 15px 25px;
  border-radius: 50px;
  border: 2px solid var(--green-light);
  outline: none;
  font-size: 1rem;
}

.search-wrapper input:focus {
  border-color: var(--green-mid);
}

/* Modal */
.modal {
  display: none;
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.8);
  z-index: 2000;
  backdrop-filter: blur(5px);
}

.modal-content {
  background: var(--white);
  width: 90%;
  max-width: 800px;
  margin: 50px auto;
  border-radius: 30px;
  max-height: 85vh;
  overflow-y: auto;
  position: relative;
  padding: 40px;
}

.close-btn {
  position: absolute;
  top: 20px;
  right: 30px;
  font-size: 2rem;
  background: none;
  border: none;
  cursor: pointer;
  color: var(--black);
}

/* Recipe Content */
.recipe-header {
  margin-bottom: 30px;
}

.recipe-header h1 {
  font-size: 2.5rem;
  margin-bottom: 10px;
}

.cooking-mode-card {
  background: var(--green-light);
  padding: 30px;
  border-radius: 20px;
  margin-bottom: 30px;
}

.step-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20px;
}

.progress-container {
  flex: 1;
  height: 8px;
  background: rgba(0, 0, 0, 0.1);
  border-radius: 4px;
  margin: 0 20px;
  overflow: hidden;
}

.progress-bar {
  height: 100%;
  background: var(--green-mid);
  width: 0%;
  transition: width 0.3s ease;
}

.step-content {
  background: var(--white);
  padding: 30px;
  border-radius: 15px;
  font-size: 1.2rem;
  min-height: 150px;
  display: flex;
  align-items: center;
  margin-bottom: 20px;
  box-shadow: 0 5px 15px rgba(0, 0, 0, 0.05);
}

.step-nav {
  display: flex;
  justify-content: center;
  gap: 20px;
}

/* Footer */
footer {
  background: #111;
  color: var(--white);
  padding: 80px 0 0;
}

.footer-content {
  display: grid;
  grid-template-columns: 2fr 1fr 1fr;
  gap: 50px;
  padding-bottom: 50px;
}

.footer-brand p {
  margin-top: 20px;
  opacity: 0.6;
  max-width: 300px;
}

.footer-links h4,
.footer-social h4 {
  margin-bottom: 20px;
  font-family: inherit;
}

.footer-links a {
  display: block;
  color: var(--white);
  text-decoration: none;
  margin-bottom: 10px;
  opacity: 0.6;
}

.footer-bottom {
  border-top: 1px solid rgba(255, 255, 255, 0.1);
  text-align: center;
  padding: 30px 0;
  color: var(--text-muted);
}

/* Responsive */
@media (max-width: 768px) {

  .nav-links,
  .nav-search {
    display: none;
  }

  .hero h1 {
    font-size: 2.5rem;
  }

  .footer-content {
    grid-template-columns: 1fr;
    text-align: center;
  }

  .footer-brand p {
    margin: 20px auto;
  }
}